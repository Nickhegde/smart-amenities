# ─── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
**/build/

# ─── Android / SDK ────────────────────────────────────────────────────────────
local.properties            # machine-specific SDK path — never commit
*.apk
*.aab
*.ap_
*.dex

# ─── IntelliJ / Android Studio ────────────────────────────────────────────────
.idea/
!.idea/.gitignore           # keep the nested .gitignore itself
*.iml
*.ipr
*.iws

# ─── Kotlin / KSP build artifacts ─────────────────────────────────────────────
.kotlin/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Keystore / signing (never commit secrets) ────────────────────────────────
*.jks
*.keystore
keystore.properties
release.properties

# ─── ProGuard ─────────────────────────────────────────────────────────────────
/app/proguard-rules.pro.bak

# ─── Test & profiling outputs ─────────────────────────────────────────────────
*.hprof
captures/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ─── Claude Code ──────────────────────────────────────────────────────────────
CLAUDE.md
.claude/
