# ─── Gradle ───────────────────────────────────────────────────────────────────
.gradle/
**/build/
gradle-wrapper.jar          # committed intentionally; remove this line if not

# ─── Android / SDK ────────────────────────────────────────────────────────────
local.properties            # contains machine-specific SDK path — never commit
*.apk
*.aab
*.ap_
*.dex

# ─── IntelliJ / Android Studio ────────────────────────────────────────────────
.idea/
!.idea/.gitignore           # keep the nested .gitignore itself
*.iml
*.ipr
*.iws

# ─── Kotlin build artifacts ───────────────────────────────────────────────────
.kotlin/

# ─── macOS ────────────────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store

# ─── Keystore / signing (never commit secrets) ────────────────────────────────
*.jks
*.keystore
keystore.properties

# ─── Proguard generated ───────────────────────────────────────────────────────
/app/proguard-rules.pro.bak

# ─── Misc ─────────────────────────────────────────────────────────────────────
*.log
captures/
